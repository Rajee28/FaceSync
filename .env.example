# .env.example
# Create a .env file with these values
# Copy this file to .env and fill in your actual values

# ===========================================
# Database Configuration
# ===========================================
DB_NAME=attendance.db

# ===========================================
# Admin Configuration
# ===========================================
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

# ===========================================
# Alert Platform Toggles
# ===========================================
# Set to "true" or "false" to enable/disable each platform
ENABLE_EMAIL_ALERTS=true
ENABLE_SMS_ALERTS=false
ENABLE_WHATSAPP_ALERTS=false

# ===========================================
# Email Configuration (SMTP)
# ===========================================
# For Gmail, you may need to enable "App Passwords":
# https://support.google.com/accounts/answer/185833
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM_NAME=FaceSync

# ===========================================
# Twilio Configuration (SMS & WhatsApp)
# ===========================================
# Get these from your Twilio Console: https://console.twilio.com
TWILIO_SID=your_account_sid
TWILIO_TOKEN=your_auth_token

# SMS Configuration
# Your Twilio phone number in E.164 format (e.g., +1234567890)
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Configuration
# Your Twilio WhatsApp-enabled number (sandbox: +14155238886)
# For sandbox testing, users must first send "join <your-sandbox-keyword>" to this number
TWILIO_WHATSAPP_NUMBER=+14155238886
